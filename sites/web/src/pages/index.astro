---
import { CopyCommand } from '~/components/CopyCommand'
import { InstallCommand } from '~/components/InstallCommand'
import { Hero } from '~/components/landing/Hero'
import { HowItLives } from '~/components/landing/HowItLives'
import { MutationFlowSection } from '~/components/landing/MutationFlowSection'
import { NotJustConfirmations } from '~/components/landing/NotJustConfirmations'
import { StackSection } from '~/components/landing/StackSection'
import { formatStarCount, getStarCount } from '~/lib/github'
import Base from '~/layouts/Base.astro'
import { getAllExamples } from '~/lib/examples'

const exampleCount = getAllExamples().length
const starsLabel = formatStarCount(await getStarCount())
---

<Base>
  <Hero client:load />
  <NotJustConfirmations exampleCount={exampleCount} client:idle />
  <HowItLives client:idle />

  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="text-center">
        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]"
        >
          Why not just React state?
        </p>
        <h2
          class="mt-3 text-3xl font-medium tracking-tight text-[var(--color-fg)] md:text-4xl"
        >
          One question. One handler.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-[var(--color-fg-muted)]">
          React state shows the dialog, but it can't hand the answer back to the
          code that opened it — so the flow splits across handlers. A{' '}
          <code class="font-mono text-sm">call()</code> returns the answer right
          where you asked.
        </p>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-2 md:gap-6">
        <div
          class="min-w-0 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6"
        >
          <div
            class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]"
          >
            React state
          </div>
          <pre
            class="mt-4 overflow-x-auto font-mono text-xs leading-relaxed text-[var(--color-fg-muted)] md:text-sm">{`// 1) the trigger just flips a flag
`}<span class="text-[var(--color-fg)]">{`const onDelete = () => setOpen(true)`}</span>{`

// 2) ...the real work lives in the dialog,
//    in a handler far from (1)
`}<span class="text-[var(--color-fg)]">{`<Confirm onAccept={() => api.delete(id)} … />`}</span></pre>
        </div>

        <div
          class="min-w-0 rounded-xl border-2 border-[var(--color-accent)] bg-[var(--color-bg-subtle)] p-6"
        >
          <div
            class="font-mono text-xs uppercase tracking-wider text-[var(--color-accent)]"
          >
            With react-call
          </div>
          <pre
            class="mt-4 overflow-x-auto font-mono text-xs leading-relaxed text-[var(--color-fg-muted)] md:text-sm">{`// one handler: ask, await, act
const onDelete = async () => {
`}<span class="text-[var(--color-fg)]">{`  if (await Confirm.call()) {
    await api.delete(id)
  }`}</span>{`
}`}</pre>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a
          href="/why"
          class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-hover)]"
        >
          Read the full case
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <StackSection client:idle />
  <MutationFlowSection client:idle />

  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-3xl px-6 py-24 text-center">
      <h2
        class="text-3xl font-medium tracking-tight text-[var(--color-fg)] md:text-4xl"
      >
        Ready to make your components{' '}
        <span class="font-mono text-[var(--color-accent)]">await</span>?
      </h2>
      <p class="mt-4 text-base text-[var(--color-fg-muted)]">
        1 KB. No deps. SSR. React Native.
      </p>
      <div class="mt-8 flex justify-center">
        <InstallCommand client:idle />
      </div>

      <div class="mt-6 flex flex-col items-center gap-2">
        <p class="font-mono text-xs text-[var(--color-fg-subtle)]">
          🤖 Building with an AI assistant?
        </p>
        <CopyCommand
          client:idle
          command="npx skills add desko27/react-call --skill react-call"
          label="Install the react-call agent skill"
        />
        <a
          href="https://github.com/desko27/react-call#ai-agent-skill"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-hover)]"
        >
          What the skill does ↗
        </a>
      </div>

      <div class="mt-8 flex items-center justify-center gap-6 text-sm">
        <a
          href="/examples"
          class="rounded-md bg-[var(--color-accent)] px-4 py-2 font-medium text-[var(--color-accent-fg)] transition-colors hover:bg-[var(--color-accent-hover)]"
        >
          Browse examples
        </a>
        <a
          href="https://github.com/desko27/react-call"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Star react-call on GitHub — ${starsLabel} stars`}
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-bg)] px-4 py-2 font-medium text-[var(--color-fg)] transition-colors hover:bg-[var(--color-bg-muted)]"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            class="h-4 w-4 text-[var(--color-accent)]"
          >
            <path
              d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
            ></path>
          </svg>
          <span>Star on GitHub</span>
          <span class="text-[var(--color-fg-subtle)]" aria-hidden="true">·</span>
          <span class="tabular-nums">{starsLabel}</span>
        </a>
      </div>
    </div>
  </section>
</Base>
