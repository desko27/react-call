---
import { InstallCommand } from '~/components/InstallCommand'
import { Hero } from '~/components/landing/Hero'
import { HowItLives } from '~/components/landing/HowItLives'
import { MutationFlowSection } from '~/components/landing/MutationFlowSection'
import { NotJustConfirmations } from '~/components/landing/NotJustConfirmations'
import { StackSection } from '~/components/landing/StackSection'
import Base from '~/layouts/Base.astro'
import { getAllExamples } from '~/lib/examples'

const exampleCount = getAllExamples().length
---

<Base>
  <Hero client:load />
  <NotJustConfirmations exampleCount={exampleCount} client:idle />
  <HowItLives client:idle />
  <StackSection client:idle />
  <MutationFlowSection client:idle />

  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-3xl px-6 py-24 text-center">
      <h2
        class="text-3xl font-medium tracking-tight text-[var(--color-fg)] md:text-4xl"
      >
        Ready to make your components{' '}
        <span class="font-mono text-[var(--color-accent)]">await</span>?
      </h2>
      <p class="mt-4 text-base text-[var(--color-fg-muted)]">
        1 KB. No deps. SSR. React Native.
      </p>
      <div class="mt-8 flex justify-center">
        <InstallCommand client:idle />
      </div>
      <div class="mt-6 flex items-center justify-center gap-6 text-sm">
        <a
          href="/examples"
          class="rounded-md bg-[var(--color-accent)] px-4 py-2 font-medium text-[var(--color-accent-fg)] transition-colors hover:bg-[var(--color-accent-hover)]"
        >
          Browse examples
        </a>
        <a
          href="https://github.com/desko27/react-call"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Star react-call on GitHub"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-bg)] px-4 py-2 font-medium text-[var(--color-fg)] transition-colors hover:bg-[var(--color-bg-muted)]"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            class="h-4 w-4 text-[var(--color-accent)]"
          >
            <path
              d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
            ></path>
          </svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</Base>
