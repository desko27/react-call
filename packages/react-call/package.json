{
  "name": "react-call",
  "version": "1.9.0-dev.0",
  "description": "Call your React components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/desko27/react-call.git"
  },
  "author": "Ismael Ramon <desko27@gmail.com> (https://desko.dev)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "module": "./dist/main.js",
  "main": "./dist/main.cjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "check:types": "tsc --noEmit",
    "test": "vitest run",
    "test:dev": "vitest",
    "bundlesize": "pnpm run build && bundlesize"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript/native-preview": "^7.0.0-dev.20250701.1",
    "@vitejs/plugin-react": "^4.6.0",
    "bundlesize": "^0.18.2",
    "happy-dom": "^20.9.0",
    "react-dom": "^19.1.0",
    "rollup-plugin-node-externals": "^8.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
